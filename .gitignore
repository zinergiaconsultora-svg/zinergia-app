# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/e2e/.auth

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
# .env.example is intentionally tracked

# vercel
.vercel

# irrelevant folders
opencode
.claude/
scripts
docs
resources
!supabase/scripts/
!supabase/scripts/**


# typescript
*.tsbuildinfo
next-env.d.ts


# irrelevant folders
opencode
scripts
docs
resources
!supabase/scripts/
!supabase/scripts/**

nul

.vercel
.env*.local
