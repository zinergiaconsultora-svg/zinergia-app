# Environment Variables for Zinergia App
# Copy this file to .env.local and fill in the values

# ========================================
# SUPABASE CONFIGURATION
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ========================================
# WEBHOOK CONFIGURATION (SECURITY)
# ========================================
# OCR Webhook URL (NEVER commit actual URLs to git)
OCR_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-ocr-webhook-id

# Comparison Webhook URL (NEVER commit actual URLs to git)
COMPARISON_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-comparison-webhook-id

# API Key for webhook authentication (Generate a strong random string)
WEBHOOK_API_KEY=your-generated-api-key-here

# ========================================
# RESEND EMAIL SERVICE
# ========================================
RESEND_API_KEY=re_your-resend-api-key

# ========================================
# SUPABASE SERVICE ROLE (server-side only, never expose to browser)
# ========================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# CRON JOBS (Vercel Cron)
# ========================================
# Generate with: openssl rand -hex 32
# Must match what Vercel sends automatically as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-generated-cron-secret

# ========================================
# WEB PUSH / PWA NOTIFICATIONS (VAPID)
# ========================================
# Generate once with: npx web-push generate-vapid-keys --json
# VAPID_SUBJECT must be a mailto: or https: URL
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@zinergia.es

# ========================================
# CNMC SIPS API (server-side only)
# ========================================
# OAuth 1.0a credentials provided by CNMC for the authorized procedure.
# Never expose these values to the browser.
CNMC_OAUTH_CONSUMER_KEY=your-cnmc-consumer-key
CNMC_OAUTH_CONSUMER_SECRET=your-cnmc-consumer-secret
CNMC_OAUTH_TOKEN=your-cnmc-token
CNMC_OAUTH_TOKEN_SECRET=your-cnmc-token-secret

# ========================================
# SECURITY NOTES
# ========================================
# 1. Never commit .env.local to git
# 2. Generate WEBHOOK_API_KEY with: openssl rand -hex 32
# 3. Generate CRON_SECRET with: openssl rand -hex 32
# 4. Generate VAPID keys with: npx web-push generate-vapid-keys --json
# 5. Rotate API keys regularly (every 90 days)
# 6. Use different keys for development and production
# 7. Monitor webhook usage for suspicious activity
